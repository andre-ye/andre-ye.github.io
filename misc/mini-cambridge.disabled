  <body data-baseurl="">
    <script>
(function () {
  if (window.self !== window.top) document.documentElement.classList.add('latex-embed--in-iframe');
})();
</script>

    <a href="#main-content" class="skip-link">Skip to main content</a>
    <script>
  window.__baseurl = (document.body && document.body.getAttribute('data-baseurl')) || '';
  window.getBase = function () { return (window.__baseurl || '').replace(/\/$/, ''); };
  window.getAssetPath = function (path) {
    var b = (typeof window.getBase === 'function' ? window.getBase() : '');
    var p = (path && path.charAt(0) === '/') ? path : '/' + (path || '');
    return b ? b + p : p;
  };
</script>

    <script src="/assets/js/latex_embed_in_frame_links.js"></script>
    
    
